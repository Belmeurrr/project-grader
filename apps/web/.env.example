NEXT_PUBLIC_API_URL=http://localhost:8000

# Clerk auth — REQUIRED in production. When unset, the web app falls
# back to dev-mode `Authorization: Dev <id>` headers (the FastAPI side
# accepts these when settings.dev_auth_enabled is true). Set both keys
# in production env config.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Dev-mode fallback identity. Only used when
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY is unset. Defaults to "dev-user".
NEXT_PUBLIC_DEV_CLERK_ID=dev-user
