ENV=dev
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://grader:grader@localhost:5432/grader
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# S3 / MinIO. In local dev, point at the docker-compose MinIO service:
#   S3_ENDPOINT_URL=http://localhost:9000
#   S3_ACCESS_KEY_ID=grader
#   S3_SECRET_ACCESS_KEY=gradergrader
#   S3_FORCE_PATH_STYLE=true
# In prod, leave S3_ENDPOINT_URL unset (defaults to AWS S3) and rely on
# the IAM role / standard AWS credential chain.
S3_BUCKET=project-grader-dev
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

CORS_ORIGINS=["http://localhost:3000"]

# Sentry — opt-in, leave unset locally
# SENTRY_DSN=

# Clerk JWT verification — required in prod. Leave unset in dev to enable
# `Authorization: Dev <id>` fallback (auto-creates User on first sight).
# CLERK_JWKS_URL=https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
# CLERK_ISSUER=https://<your-instance>.clerk.accounts.dev
